# NexusMail Environment Variables Template
# Copy this file to .env and fill in your actual values

# ===================
# Database
# ===================
MARIADB_ROOT_PASSWORD=your_root_password
MARIADB_DATABASE=nexusmail
MARIADB_USER=nexusmail
MARIADB_PASSWORD=your_password

# ===================
# JWT Security
# ===================
JWT_SECRET_KEY=your_super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===================
# Google OAuth & Gmail API
# ===================
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/nexusmail-gmail
GMAIL_WEBHOOK_VERIFICATION_TOKEN=your_webhook_verification_token

# ===================
# OpenAI (for AI Classification)
# ===================
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ===================
# Qdrant (Vector DB for RAG)
# ===================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=nexusmail_feedback

# ===================
# Redis (Caching & Pub/Sub)
# ===================
REDIS_HOST=localhost
REDIS_PORT=6379

# ===================
# App Settings
# ===================
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CLIENT_URL=http://localhost:5173

# ===================
# Frontend (Vite)
# ===================
VITE_API_BASE_URL=http://localhost:8000
